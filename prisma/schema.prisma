datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @default("") @map("password_hash")
  name         String
  initials     String?
  permissions  String?  // JSON: { can_view_cap_table, can_view_waterfall, can_view_documents, can_download, can_message }
  role         String    @default("INVESTOR") // INVESTOR | ADMIN | GP
  joined       String?   // "March 2023" display string
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  investorProjects    InvestorProject[]
  sentMessages        Message[] @relation("sender")
  messageRecipients   MessageRecipient[]
  documentAssignments DocumentAssignment[]
  createdThreads      MessageThread[] @relation("threadCreator")
  threadMessages      ThreadMessage[] @relation("threadMessageSender")
  threadRecipients    ThreadRecipient[] @relation("threadRecipient")
  groupMemberships    GroupMember[]
  signatureRequests    SignatureRequest[] @relation("signatureCreator")
  signerRecords        SignatureSigner[]  @relation("signerUser")
  notificationLogs     NotificationLog[]
  notificationPrefs    NotificationPreference?
  cashFlows            CashFlow[]
  auditLogs            AuditLog[]
  entities             InvestorEntity[]
  loginHistory         LoginHistory[]
  statementsAsUser      Statement[]    @relation("statementUser")
  statementsAsCreator   Statement[]    @relation("statementCreator")
  statementsAsApprover  Statement[]    @relation("statementApprover")
  statementsAsRejector  Statement[]    @relation("statementRejector")
  featureFlagOverrides  FeatureFlagOverride[]
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedUntil          DateTime? @map("locked_until")
  resetToken           String?   @map("reset_token")
  resetTokenExpiry     DateTime? @map("reset_token_expiry")
  mfaSecret            String?   @map("mfa_secret")
  mfaEnabled           Boolean   @default(false) @map("mfa_enabled")
  mfaBackupCodes       String?   @map("mfa_backup_codes") // JSON array of hashed backup codes
  accreditationStatus  String?   @map("accreditation_status") // not_verified | pending | verified | expired
  accreditationDate    DateTime? @map("accreditation_date")
  accreditationExpiry  DateTime? @map("accreditation_expiry")
  accreditationType    String?   @map("accreditation_type") // income | net_worth | entity | professional

  @@map("users")
}

model Project {
  id                  Int       @id @default(autoincrement())
  name                String
  location            String?
  type                String?
  status              String   // Under Construction | Pre-Development | Completed
  description         String?
  sqft                String?
  units               Int?
  completionPct       Int      @default(0) @map("completion_pct")
  totalRaise          Float    @default(0) @map("total_raise")
  prefReturnPct       Float    @default(8.0) @map("pref_return_pct")
  gpCatchupPct        Float    @default(100) @map("gp_catchup_pct")
  carryPct            Float    @default(20) @map("carry_pct")
  estimatedCompletion DateTime? @map("estimated_completion")
  unitsSold           Int       @default(0) @map("units_sold")
  revenue             Float     @default(0)
  orgChart            String?   @map("org_chart") // JSON string: [{role, name, company}]
  imageUrl            String?   @map("image_url") // URL or storage key for project hero image
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  investorProjects   InvestorProject[]
  capTableEntries    CapTableEntry[]
  waterfallTiers     WaterfallTier[]
  distributions      Distribution[]
  documents          Document[]
  updates            ProjectUpdate[]
  performanceHistory PerformanceHistory[]
  targetedMessages   Message[] @relation("messageTarget")
  targetedThreads    MessageThread[] @relation("threadTarget")
  prospects          Prospect[]
  cashFlows          CashFlow[]
  statements         Statement[]    @relation("statementProject")

  @@map("projects")
}

model InvestorProject {
  id           Int   @id @default(autoincrement())
  userId       Int   @map("user_id")
  projectId    Int   @map("project_id")
  committed    Float @default(0)
  called       Float @default(0)
  currentValue Float @default(0) @map("current_value")
  irr          Float?
  moic         Float?
  entityId     Int?  @map("entity_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User              @relation(fields: [userId], references: [id])
  project Project           @relation(fields: [projectId], references: [id])
  entity  InvestorEntity?   @relation(fields: [entityId], references: [id])

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("investor_projects")
}

model CapTableEntry {
  id           Int    @id @default(autoincrement())
  projectId    Int    @map("project_id")
  holderName   String @map("holder_name")
  holderType   String @map("holder_type") // GP Interest | LP — Class A | LP — Class B | LP — Class C
  committed    Float  @default(0)
  called       Float  @default(0)
  ownershipPct Float  @map("ownership_pct")
  unfunded     Float  @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("cap_table_entries")
}

model WaterfallTier {
  id        Int    @id @default(autoincrement())
  projectId Int    @map("project_id")
  tierOrder Int    @map("tier_order")
  tierName  String @map("tier_name")
  lpShare   String @map("lp_share")  // "100%", "80%"
  gpShare   String @map("gp_share")  // "0%", "20%"
  threshold String?
  status    String @default("pending") // pending | accruing | complete
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, tierOrder])
  @@map("waterfall_tiers")
}

model Distribution {
  id        Int    @id @default(autoincrement())
  projectId Int    @map("project_id")
  quarter   String // "Q3 2024"
  date      String // "Oct 8, 2024"
  amount    Float
  type      String // Income | Capital Return
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("distributions")
}

model Document {
  id        Int    @id @default(autoincrement())
  projectId Int?   @map("project_id") // null for general docs
  name      String
  category  String // Reporting | Property Update | Offering | Capital Call | Legal | Tax | Distribution
  date      String // "Jul 15, 2025"
  size      String // "2.4 MB"
  status    String @default("published") // published | action_required | pending_signature
  file       String // "/docs/filename.pdf" or "/uploads/..."
  storageKey String? @map("storage_key") // key in storage adapter (local path or S3 key)
  createdAt  DateTime @default(now()) @map("created_at")

  project     Project?             @relation(fields: [projectId], references: [id])
  assignments DocumentAssignment[]
  signatureRequests    SignatureRequest[]

  @@index([projectId])
  @@map("documents")
}

model ProjectUpdate {
  id            Int      @id @default(autoincrement())
  projectId     Int      @map("project_id")
  date          String   // "Jun 28, 2025"
  text          String
  completionPct Int?     @map("completion_pct_snapshot")
  unitsSold     Int?     @map("units_sold_snapshot")
  revenue       Float?   @map("revenue_snapshot")
  status        String?  @map("status_snapshot")
  photoUrl      String?  @map("photo_url")
  createdAt     DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("project_updates")
}

model PerformanceHistory {
  id        Int    @id @default(autoincrement())
  projectId Int    @map("project_id")
  month     String // "Jan", "Feb", etc.
  value     Float
  benchmark Float
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("performance_history")
}

model Message {
  id         Int     @id @default(autoincrement())
  senderId   Int     @map("sender_id")
  fromName   String  @map("from_name")
  role       String
  date       String  // "Jul 18, 2025"
  subject    String
  preview    String
  unread     Boolean @default(true)
  // Targeting: ALL = everyone, PROJECT = investors in a project, INDIVIDUAL = specific users
  targetType String  @default("ALL") @map("target_type") // ALL | PROJECT | INDIVIDUAL
  targetProjectId Int? @map("target_project_id") // if targetType = PROJECT
  createdAt  DateTime @default(now()) @map("created_at")

  sender         User              @relation("sender", fields: [senderId], references: [id])
  targetProject  Project?          @relation("messageTarget", fields: [targetProjectId], references: [id])
  recipients     MessageRecipient[]

  @@index([senderId])
  @@map("messages")
}

model MessageRecipient {
  id        Int @id @default(autoincrement())
  messageId Int @map("message_id")
  userId    Int @map("user_id")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_recipients")
}

// ─── THREADED MESSAGING ──────────────────────────────────

model MessageThread {
  id              Int      @id @default(autoincrement())
  subject         String
  creatorId       Int      @map("creator_id")
  targetType      String   @default("ALL") @map("target_type") // ALL | PROJECT | INDIVIDUAL | STAFF
  targetProjectId Int?     @map("target_project_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  creator        User              @relation("threadCreator", fields: [creatorId], references: [id])
  targetProject  Project?          @relation("threadTarget", fields: [targetProjectId], references: [id])
  messages       ThreadMessage[]
  recipients     ThreadRecipient[]

  @@map("message_threads")
}

model ThreadMessage {
  id        Int      @id @default(autoincrement())
  threadId  Int      @map("thread_id")
  senderId  Int      @map("sender_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("threadMessageSender", fields: [senderId], references: [id])

  @@map("thread_messages")
}

model ThreadRecipient {
  id       Int       @id @default(autoincrement())
  threadId Int       @map("thread_id")
  userId   Int       @map("user_id")
  unread   Boolean   @default(true)
  readAt   DateTime? @map("read_at")

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation("threadRecipient", fields: [userId], references: [id])

  @@unique([threadId, userId])
  @@map("thread_recipients")
}

model DocumentAssignment {
  id             Int       @id @default(autoincrement())
  documentId     Int       @map("document_id")
  userId         Int       @map("user_id")
  viewedAt       DateTime? @map("viewed_at")
  downloadedAt   DateTime? @map("downloaded_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([documentId, userId])
  @@index([userId])
  @@index([documentId])
  @@map("document_assignments")
}

// ─── INVESTOR ENTITIES ──────────────────────────────────

model InvestorEntity {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  name        String   // "Chen Family Trust", "Pacific Ventures LLC"
  type        String   // Individual | LLC | Trust | IRA | Corporation | Partnership
  taxId       String?  @map("tax_id") // EIN or SSN (encrypted in production)
  address     String?
  state       String?  // state of formation
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])
  investments InvestorProject[]

  @@map("investor_entities")
}

// ─── INVESTOR GROUPS / SEGMENTS ──────────────────────────

model InvestorGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  color       String?  // hex color for UI badges
  parentId    Int?     @map("parent_id")
  tier        String   @default("primary") // primary | sub-lp | fund-of-funds
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent      InvestorGroup?  @relation("groupHierarchy", fields: [parentId], references: [id])
  children    InvestorGroup[] @relation("groupHierarchy")
  members     GroupMember[]

  @@map("investor_groups")
}

model GroupMember {
  id      Int @id @default(autoincrement())
  groupId Int @map("group_id")
  userId  Int @map("user_id")

  group InvestorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("group_members")
}

// ─── E-SIGNATURE ────────────────────────────────────────

model SignatureRequest {
  id             Int       @id @default(autoincrement())
  documentId     Int       @map("document_id")
  requestId      String    @unique @map("request_id") // external provider ID
  status         String    @default("pending") // pending | signed | declined | expired | cancelled
  subject        String?
  message        String?
  createdById    Int       @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  completedAt    DateTime? @map("completed_at")

  document    Document @relation(fields: [documentId], references: [id])
  createdBy   User     @relation("signatureCreator", fields: [createdById], references: [id])
  signers     SignatureSigner[]

  @@map("signature_requests")
}

model SignatureSigner {
  id          Int       @id @default(autoincrement())
  requestId   Int       @map("request_id")
  userId      Int?      @map("user_id") // null if external signer
  name        String
  email       String
  status      String    @default("pending") // pending | signed | declined
  signedAt    DateTime? @map("signed_at")
  signUrl     String?   @map("sign_url")

  request     SignatureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user        User?            @relation("signerUser", fields: [userId], references: [id])

  @@map("signature_signers")
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model NotificationLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  type       String   // document_uploaded | signature_required | signature_completed | distribution_paid | new_message | capital_call
  subject    String
  channel    String   @default("email") // email | in_app
  status     String   @default("sent") // sent | failed | pending
  metadata   String?  // JSON blob with extra context
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notification_logs")
}

model NotificationPreference {
  id                   Int     @id @default(autoincrement())
  userId               Int     @unique @map("user_id")
  emailDocuments       Boolean @default(true) @map("email_documents")
  emailSignatures      Boolean @default(true) @map("email_signatures")
  emailDistributions   Boolean @default(true) @map("email_distributions")
  emailMessages        Boolean @default(true) @map("email_messages")
  emailCapitalCalls    Boolean @default(true) @map("email_capital_calls")

  user User @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

// ─── PROSPECTS (prospective investors) ─────────────────

model Prospect {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String
  phone               String?
  entityType          String?  @map("entity_type") // Individual | LLC | Trust | IRA
  accreditationStatus String?  @map("accreditation_status") // Accredited | Not Yet | Unsure
  investmentRange     String?  @map("investment_range") // $50K-$100K | $100K-$250K | $250K-$500K | $500K+
  interestedProjectId Int?     @map("interested_project_id")
  message             String?
  status              String   @default("new") // new | contacted | qualified | converted | declined
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  leadSource          String?  @map("lead_source") // Website | Referral | Event | Cold Outreach | Other
  notes               String?
  followUpDate        DateTime? @map("follow_up_date")

  interestedProject Project? @relation(fields: [interestedProjectId], references: [id])

  @@map("prospects")
}

// ─── AUDIT LOG ─────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   // login | logout | document_download | document_upload | signature_request | signature_sign | profile_update | investor_invite | project_update | cash_flow_record | prospect_submit
  resource   String?  // "document:15" | "project:2" | "user:5"
  details    String?  // JSON blob with extra context
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ─── CASH FLOWS (financial engine) ────────────────────────

model CashFlow {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  userId      Int      @map("user_id")
  date        DateTime
  amount      Float    // negative = capital call/investment, positive = distribution
  type        String   // capital_call | distribution | return_of_capital | income
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@map("cash_flows")
}

// ─── LOGIN HISTORY ────────────────────────────────────────

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  ip        String?
  userAgent String?  @map("user_agent")
  success   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("login_history")
}

// ─── STATEMENTS (capital account statements with approval workflow) ──

model Statement {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  projectId     Int       @map("project_id")
  status        String    @default("DRAFT") // DRAFT | APPROVED | SENT | REJECTED
  data          String?   @db.Text // JSON blob with full statement data
  html          String?   @db.Text // Rendered HTML
  period        String?   // e.g. "Q1 2026"
  createdBy     Int?      @map("created_by")
  approvedBy    Int?      @map("approved_by")
  approvedAt    DateTime? @map("approved_at")
  rejectedBy    Int?      @map("rejected_by")
  rejectedAt    DateTime? @map("rejected_at")
  rejectReason  String?   @map("reject_reason")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation("statementUser", fields: [userId], references: [id])
  project       Project   @relation("statementProject", fields: [projectId], references: [id])
  creator       User?     @relation("statementCreator", fields: [createdBy], references: [id])
  approver      User?     @relation("statementApprover", fields: [approvedBy], references: [id])
  rejector      User?     @relation("statementRejector", fields: [rejectedBy], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("statements")
}

// ─── FEATURE FLAG OVERRIDES (persisted per-user) ────────

model FeatureFlagOverride {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  flagKey   String   @map("flag_key")
  value     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, flagKey])
  @@index([userId])
  @@map("feature_flag_overrides")
}

// ─── EMAIL SETTINGS (singleton — one row) ────────────────

model EmailSettings {
  id                    Int      @id @default(autoincrement())
  // Global toggles (admin can disable email types system-wide)
  enableDocuments       Boolean  @default(true) @map("enable_documents")
  enableSignatures      Boolean  @default(true) @map("enable_signatures")
  enableDistributions   Boolean  @default(true) @map("enable_distributions")
  enableMessages        Boolean  @default(true) @map("enable_messages")
  enableCapitalCalls    Boolean  @default(true) @map("enable_capital_calls")
  enableWelcome         Boolean  @default(true) @map("enable_welcome")
  enablePasswordReset   Boolean  @default(true) @map("enable_password_reset")
  // Branding overrides
  fromName              String?  @map("from_name")
  fromAddress           String?  @map("from_address")
  replyToAddress        String?  @map("reply_to_address")
  brandColor            String?  @map("brand_color")
  companyName           String?  @map("company_name")
  companyAddress        String?  @map("company_address")
  logoUrl               String?  @map("logo_url")
  portalUrl             String?  @map("portal_url")
  // Custom subject line overrides (null = use defaults)
  subjectWelcome        String?  @map("subject_welcome")
  subjectDocument       String?  @map("subject_document")
  subjectSignature      String?  @map("subject_signature")
  subjectDistribution   String?  @map("subject_distribution")
  subjectMessage        String?  @map("subject_message")
  subjectCapitalCall    String?  @map("subject_capital_call")
  subjectPasswordReset  String?  @map("subject_password_reset")
  // Footer
  footerText            String?  @map("footer_text")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}
